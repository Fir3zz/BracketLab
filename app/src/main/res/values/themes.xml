<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#FFFFFF</item>
        <item name="colorPrimaryVariant">#0d0d1a</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#00FF88</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="colorButtonNormal">#000000</item>
        <item name="android:colorButtonNormal">#000000</item>
        <item name="buttonStyle">@style/DbeButton</item>
        <item name="android:buttonStyle">@style/DbeButton</item>
        <item name="android:windowBackground">#1a1a1a</item>
        <item name="android:forceDarkAllowed" tools:targetApi="29">false</item>
    </style>

    <style name="DbeButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/dbe_button</item>
        <item name="android:backgroundTint">@null</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="DbeColumnButton" parent="@style/DbeButton">
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingRight">0dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:includeFontPadding">true</item>
        <item name="android:lineSpacingExtra">0dp</item>
    </style>
</resources>
